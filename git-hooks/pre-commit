#!/usr/bin/env bash
# Pre-commit hook: Shai-Hulud / TeamPCP supply chain audit.
#
# Default (fast, ~1-2s):
#   - Project-level: scripts/detect_compromise.py (if present)
#
# Opt-in (slow, ~5min — kept out of commit path; runs in CI instead):
#   - Machine-level: ~/.shai-hulud/shai-hulud-audit.{sh,ps1}
#     Re-enable by exporting SHAI_HULUD_MACHINE_AUDIT=1 in your shell.
#
# Exits non-zero on alerts (commit blocked). Warnings are reported but don't block.
#
# To install: cp this file to .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# To skip in an emergency: git commit --no-verify (use sparingly)

set -u

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [[ -z "$REPO_ROOT" ]]; then
    echo "pre-commit: not in a git repo, skipping audit" >&2
    exit 0
fi

YELLOW='\033[33m'
RED='\033[31m'
GREEN='\033[32m'
RESET='\033[0m'

FAILED=0

# --- Skip scan when no dep-related files in this commit ---
# Supply chain risk only materializes when dep manifests change. If this commit
# touches only source code, the scan adds no signal and ~45s of latency.
# Override: SHAI_HULUD_FORCE=1 to always scan.
DEP_PATTERN='(^|/)(requirements[^/]*\.txt|package(-lock)?\.json|pnpm-lock\.yaml|yarn\.lock|pyproject\.toml|Pipfile(\.lock)?|poetry\.lock|uv\.lock|[^/]*\.pth|\.github/workflows/.*\.ya?ml|\.claude/.*\.(js|mjs|json))$'
if [[ "${SHAI_HULUD_FORCE:-0}" != "1" ]]; then
    if ! git diff --cached --name-only | grep -Eq "$DEP_PATTERN"; then
        echo -e "${GREEN}[pre-commit] no dep/workflow changes — skipping supply chain audit${RESET}" >&2
        exit 0
    fi
fi

# --- Project-level scan ---
PROJECT_SCRIPT="$REPO_ROOT/scripts/detect_compromise.py"
if [[ -f "$PROJECT_SCRIPT" ]]; then
    echo "[pre-commit] running project audit (dep/workflow files changed)..."
    if command -v python3 >/dev/null 2>&1; then
        PY=python3
    elif command -v python >/dev/null 2>&1; then
        PY=python
    else
        echo "${YELLOW}pre-commit: no python found, skipping project audit${RESET}" >&2
        PY=""
    fi

    if [[ -n "$PY" ]]; then
        $PY "$PROJECT_SCRIPT" --root "$REPO_ROOT"
        code=$?
        if [[ $code -ge 2 ]]; then
            echo -e "${RED}[pre-commit] project audit FAILED (alerts present)${RESET}" >&2
            FAILED=1
        elif [[ $code -eq 1 ]]; then
            echo -e "${YELLOW}[pre-commit] project audit has warnings (continuing)${RESET}" >&2
        fi
    fi
fi

# --- Machine-level scan: DISABLED on pre-commit (too slow: ~5min/commit) ---
# Machine-wide OSV.dev round-trips are kept out of the commit path. They still
# run in CI (.github/workflows/supply-chain-audit.yml: PR + nightly) and
# you can invoke them manually anytime with `/hulud-kit quick` in Claude Code.
# To re-enable here, set SHAI_HULUD_MACHINE_AUDIT=1 in your shell.
if [[ "${SHAI_HULUD_MACHINE_AUDIT:-0}" = "1" ]]; then
    if [[ -f "$HOME/.shai-hulud/shai-hulud-audit.sh" ]]; then
        MACHINE_SCRIPT="$HOME/.shai-hulud/shai-hulud-audit.sh"
        echo "[pre-commit] running machine audit (quick mode)..."
        "$MACHINE_SCRIPT" --mode quick --quiet
        code=$?
        if [[ $code -ge 2 ]]; then
            echo -e "${RED}[pre-commit] machine audit FAILED (alerts present)${RESET}" >&2
            echo "Run '/hulud-kit quick' or '$MACHINE_SCRIPT --mode quick' for details." >&2
            FAILED=1
        elif [[ $code -eq 1 ]]; then
            echo -e "${YELLOW}[pre-commit] machine audit has warnings (continuing)${RESET}" >&2
        fi
    elif command -v pwsh >/dev/null 2>&1 && [[ -f "$HOME/.shai-hulud/shai-hulud-audit.ps1" ]]; then
        echo "[pre-commit] running machine audit via pwsh..."
        pwsh -NoProfile -File "$HOME/.shai-hulud/shai-hulud-audit.ps1" -Mode quick -Quiet
        code=$?
        if [[ $code -ge 2 ]]; then
            echo -e "${RED}[pre-commit] machine audit FAILED (alerts present)${RESET}" >&2
            FAILED=1
        elif [[ $code -eq 1 ]]; then
            echo -e "${YELLOW}[pre-commit] machine audit has warnings (continuing)${RESET}" >&2
        fi
    fi
fi

if [[ $FAILED -ne 0 ]]; then
    echo "" >&2
    echo -e "${RED}Commit blocked by supply chain audit.${RESET}" >&2
    echo "  - Review the findings above" >&2
    echo "  - See docs/security/IOC_DETECTION_CHECKLIST.md if you have one" >&2
    echo "  - Use 'git commit --no-verify' to bypass (only if you've confirmed safe)" >&2
    exit 1
fi

echo -e "${GREEN}[pre-commit] supply chain audit clean${RESET}" >&2
exit 0
